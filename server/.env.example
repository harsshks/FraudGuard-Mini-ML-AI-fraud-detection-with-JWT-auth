# ── MongoDB ──────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fraudguard

# ── Google Gemini API ────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── ML Service ───────────────────────────────────
ML_SERVICE_URL=http://localhost:5001

# ── JWT Auth ──────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Server Port ──────────────────────────────────
PORT=5000
